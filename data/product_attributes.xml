        </record>
        <record id="attr_val_view_forest" model="product.attribute.value">
            <field name="name">🌲 Na las</field>
            <field name="attribute_id" ref="attr_view"/>
            <field name="sequence">2</field>
        </record>
        <record id="attr_val_view_lake" model="product.attribute.value">
