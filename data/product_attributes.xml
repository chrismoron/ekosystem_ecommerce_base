        <!-- ============================================ -->

        <record id="attr_equipment_condition" model="product.attribute">
            <field name="name">Stan sprzętu</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
        </record>
        <record id="attr_val_eq_new" model="product.attribute.value">
            <field name="name">✨ Nowy (bieżący rok)</field>
            <field name="attribute_id" ref="attr_equipment_condition"/>
            <field name="sequence">1</field>
        </record>
        <record id="attr_val_eq_good" model="product.attribute.value">
            <field name="name">👍 Dobry</field>
            <field name="attribute_id" ref="attr_equipment_condition"/>
            <field name="sequence">2</field>
        </record>
        <record id="attr_val_eq_used" model="product.attribute.value">
