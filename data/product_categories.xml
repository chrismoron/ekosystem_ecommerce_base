            <field name="parent_id" ref="categ_equipment"/>
        </record>

        <record id="categ_equipment_outdoor" model="product.category">
            <field name="name">Sprzęt outdoorowy</field>
            <field name="parent_id" ref="categ_equipment"/>
        </record>

        <record id="categ_packages" model="product.category">
            <field name="name">Pakiety</field>
        </record>

    </data>
</odoo>
