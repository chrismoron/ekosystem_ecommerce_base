        </record>

        <record id="categ_gastronomy_restaurant" model="product.category">
            <field name="name">Restauracja</field>
            <field name="parent_id" ref="categ_gastronomy"/>
        </record>

        <record id="categ_gastronomy_catering" model="product.category">
            <field name="name">Catering</field>
            <field name="parent_id" ref="categ_gastronomy"/>
        </record>

        <record id="categ_transport" model="product.category">
            <field name="name">Transport</field>
        </record>

        <record id="categ_transport_bikes" model="product.category">
            <field name="name">Rowery</field>
            <field name="parent_id" ref="categ_transport"/>
        </record>

        <record id="categ_transport_vehicles" model="product.category">
            <field name="name">Pojazdy</field>
            <field name="parent_id" ref="categ_transport"/>
        </record>

        <record id="categ_equipment" model="product.category">
