<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================ -->
        <!-- INTERNAL PRODUCT CATEGORIES                  -->
        <!-- (product.category - for accounting/internal) -->
        <!-- ============================================ -->

        <record id="categ_accommodation" model="product.category">
            <field name="name">Noclegi</field>
        </record>

        <record id="categ_accommodation_rooms" model="product.category">
            <field name="name">Pokoje</field>
            <field name="parent_id" ref="categ_accommodation"/>
        </record>

        <record id="categ_accommodation_houses" model="product.category">
            <field name="name">Domki</field>
            <field name="parent_id" ref="categ_accommodation"/>
        </record>

        <record id="categ_accommodation_camping" model="product.category">
            <field name="name">Camping / Glamping</field>
            <field name="parent_id" ref="categ_accommodation"/>
        </record>

        <record id="categ_activities" model="product.category">
            <field name="name">Aktywności</field>
        </record>

        <record id="categ_activities_water" model="product.category">
            <field name="name">Sporty wodne</field>
            <field name="parent_id" ref="categ_activities"/>
        </record>

        <record id="categ_activities_land" model="product.category">
            <field name="name">Sporty lądowe</field>
            <field name="parent_id" ref="categ_activities"/>
        </record>

        <record id="categ_activities_tours" model="product.category">
            <field name="name">Wycieczki</field>
